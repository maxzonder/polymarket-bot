#!/usr/bin/env python3
from __future__ import annotations

import importlib.util
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
REPO_ROOT = ROOT.parents[1]
VENV_PYTHON = REPO_ROOT / ".venv" / "bin" / "python"


def _prefer_repo_venv() -> None:
    if not VENV_PYTHON.exists():
        return

    if importlib.util.find_spec("structlog") is not None:
        return

    active_prefix = Path(sys.prefix).resolve()
    target_prefix = VENV_PYTHON.parent.parent.resolve()
    if active_prefix == target_prefix:
        return

    probe = subprocess.run(
        [str(VENV_PYTHON), "-c", "import structlog"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    if probe.returncode != 0:
        return

    os.execv(str(VENV_PYTHON), [str(VENV_PYTHON), str(Path(__file__).resolve()), *sys.argv[1:]])


_prefer_repo_venv()

if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from short_horizon.replay_runner import main


if __name__ == "__main__":
    main()
